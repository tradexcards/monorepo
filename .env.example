# ══════════════════════════════════════════════════════════════════════════════
# TradeX — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Single .env file for the entire monorepo.
# Copy this to .env and fill in your values:
#   cp .env.example .env
#

# ══════════════════════════════════════════════════════════════════════════════
# SHARED (used by backend, frontend, and program scripts)
# ══════════════════════════════════════════════════════════════════════════════

# ── Network ───────────────────────────────────────────────────────────────────
# "true" for mainnet-beta, "false" for devnet
MAINNET=true

# ── Program ID ────────────────────────────────────────────────────────────────
# Mainnet: TRDXCHHWWZdQXxkGFJxek1KU2hn19687xztNBy99Ca1
PROGRAM_ID=TRDXCHHWWZdQXxkGFJxek1KU2hn19687xztNBy99Ca1

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Required for mainnet. Use a private RPC (Helius, QuickNode, Triton, etc.)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_FALLBACK_URL=

# ── USDC Mint ─────────────────────────────────────────────────────────────────
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ══════════════════════════════════════════════════════════════════════════════
# BACKEND
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=false
TRUST_PROXY=false

# ── Admin ─────────────────────────────────────────────────────────────────────
# Required for mainnet (16+ characters)
ADMIN_PASSWORD=

# ── Oracle/Keeper ─────────────────────────────────────────────────────────────
# Paths relative to monorepo root
ORACLE_KEYPAIR_PATH=./keypair.json
KEEPER_KEYPAIR_PATH=./keypair.json
KEEPER_ENABLED=true
KEEPER_UPDATE_INTERVAL=300

# ── Proxy (Bright Data) ───────────────────────────────────────────────────────
# Optional: Enable proxy for TCGPlayer requests to avoid rate limits
PROXY_ENABLED=false
PROXY_HOST=brd.superproxy.io
PROXY_PORT=33335
PROXY_USER=
PROXY_PASS=
PROXY_COUNTRY=us

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND
# ══════════════════════════════════════════════════════════════════════════════

# Frontend uses BUN_PUBLIC_* prefix for client-side access
BUN_PUBLIC_MAINNET=${MAINNET}
BUN_PUBLIC_PROGRAM_ID=${PROGRAM_ID}
BUN_PUBLIC_RPC_URL=${SOLANA_RPC_URL}
BUN_PUBLIC_USDC_MINT=${USDC_MINT}
BUN_PUBLIC_BACKEND_URL=http://localhost:8001

# ══════════════════════════════════════════════════════════════════════════════
# PROGRAM SCRIPTS (deploy, init, status)
# ══════════════════════════════════════════════════════════════════════════════

# Path to admin/authority keypair (relative to monorepo root)
KEYPAIR_PATH=./keypair.json
