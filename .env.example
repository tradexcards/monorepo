# ══════════════════════════════════════════════════════════════════════════════
# TradeX — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# The backend reads this file. The frontend has all config hardcoded in
# frontend/src/lib/config.ts — no env vars needed for the frontend.

# ── Network ───────────────────────────────────────────────────────────────────
# true = mainnet-beta, false = devnet
BUN_PUBLIC_MAINNET=true

# ── RPC ───────────────────────────────────────────────────────────────────────
# Required on mainnet. Use a paid RPC (Helius, QuickNode, Triton, etc.)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# ── Admin ─────────────────────────────────────────────────────────────────────
# Must be 16+ characters on mainnet
ADMIN_PASSWORD=CHANGE_ME

# ── Keypairs ──────────────────────────────────────────────────────────────────
# Paths relative to backend/ dir. Place keypair.json at project root.
ORACLE_KEYPAIR_PATH=../keypair.json
KEEPER_KEYPAIR_PATH=../keypair.json

# ── Bright Data Proxy ────────────────────────────────────────────────────────
# Recommended for production to avoid TCGPlayer rate limits
PROXY_ENABLED=false
PROXY_USER=
PROXY_PASS=
PROXY_COUNTRY=US

# ── Optional overrides (defaults are fine) ────────────────────────────────────
# HOST=0.0.0.0
# PORT=8001
# DEBUG=false
# TRUST_PROXY=false
# KEEPER_ENABLED=true
# ORACLE_MAX_PRICE_AGE=15
