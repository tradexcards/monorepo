{
  "name": "tradex-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "bun install --cwd backend && bun install --cwd frontend && bun install --cwd mcp-server && bun install --cwd program",
    "install:backend": "bun install --cwd backend",
    "install:frontend": "bun install --cwd frontend",
    "install:mcp": "bun install --cwd mcp-server",
    "install:program": "bun install --cwd program",
    "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build:frontend": "bun run --cwd frontend build",
    "build:program": "cd program && ./scripts/build.sh",
    "start:backend": "bun run --cwd backend start",
    "start:frontend": "bun run --cwd frontend preview"
  }
}
